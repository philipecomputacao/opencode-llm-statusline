# OpenCode local config (paths, providers, model prefs) — keep private
opencode.jsonc
package.json
package-lock.json
node_modules/

# Plugin output cache
.opencode/
.cache/

# Unrelated plugins (not part of this repo)
plugins/cc-statusline/
plugins/cc-statusline/node_modules/

# Vendored Python runtime cache
python/__pycache__/
python/lib/__pycache__/

# OS / editor cruft
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Secrets, credentials, and local config (preventive — none should land here)
.env
.env.*
*.pem
*.key
*.p12
*.pfx
credentials
secrets
*.log
*.sqlite
*.db
*.sqlite3
